# Variables de entorno del ENTORNO DEMO (Andex). Copiá a un .env real (NO se
# commitea) o cargalas en el App Service. NINGÚN secreto real va acá: este archivo
# es solo la plantilla con placeholders.
#
# Local (screen-share, Fases 0-4):  basta con el bloque [NÚCLEO] + [DATOS].
# En vivo en Teams (Fase 5):        sumá [BOT / AZURE] con los recursos demo.

# ===== [NÚCLEO] tenant + sandbox anti-fuga =====
DEMO_MODE=1
TENANT_CONFIG_SOURCE=yaml
TENANT_SLUG=andex
DEMO_EMAIL_DOMAIN=andexdemo.com
DEMO_EMAIL_TO=demo@andexdemo.com          # toda salida de correo se redirige acá
DEMO_FROM_USER=amora@andexdemo.com        # remitente demo
DEMO_SUBJECT_PREFIX=[DEMO]
STATE_DIR=C:\Users\Mateo\.andex-demo       # estado del equipo (dedicado, NO el real)
# DEMO_TODAY=2026-06-24                    # opcional: fija "hoy" para ensayos

# ===== [DATOS] (con DEMO_MODE=1 NO se usan las APIs reales; tokens dummy ok) =====
CONTIFICO_API_TOKEN=demo
HUBSPOT_TOKEN=demo
ANTHROPIC_API_KEY=sk-ant-...               # SÍ real: lo usa el Data Bot (Claude)

# ===== [BOT / AZURE] solo para la Fase 5 (bots en vivo en Teams) =====
# Recursos del TENANT M365 DEMO (separados de producción). Ver DEMO_FASE5_RUNBOOK.md.
MICROSOFT_APP_ID=REEMPLAZAR_CON_DEMO_DATA_BOT_APP_ID
MICROSOFT_APP_PASSWORD=REEMPLAZAR_CON_DEMO_DATA_BOT_SECRET
MICROSOFT_APP_TENANT_ID=REEMPLAZAR_CON_DEMO_TENANT_ID
ADMIN_API_TOKEN=REEMPLAZAR_CON_TOKEN_ADMIN_DEMO
# Allowlists del demo (correos del tenant M365 demo). Si vacío, el Data Bot se cierra.
BOT_ALLOWED_USERS_DATA=rsalinas@andexdemo.com,cvega@andexdemo.com,amora@andexdemo.com
TRACKER_TARGET_USER=amora@andexdemo.com
# Mapeo AAD->email del tenant demo (si Teams no manda el email en props):
# AAD_ID_TO_EMAIL=<aad_short>:rsalinas@andexdemo.com,<aad_short>:cvega@andexdemo.com
