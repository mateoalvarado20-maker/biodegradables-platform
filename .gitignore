# Este repo vive en el home dir del usuario: se ignora TODO por defecto
# y se whitelistea solo lo que pertenece al proyecto.
/*

# --- Proyecto: código y docs ---
!/.gitignore
!/CLAUDE.md
!/AUDITORIA_TECNICA_2026-06-12.md
!/AUTOMATIZACIONES_EMPRESA.md
!/PROPUESTA_ARQUITECTURA_MULTIEMPRESA.md
!/PROPUESTA_DEMO_COMERCIAL.md
!/PROPUESTA_TIKTOK_MEDIA_MANAGER.md
!/PROPUESTA_VER_OS.md
!/DEMO_GUION.md
!/DEMO_FASE5_RUNBOOK.md
!/.env.demo.example
!/azure_setup_checklist.md
!/company_context.md
!/*.py
!/run_*.bat
!/requirements.txt
!/requirements_bot.txt
!/requirements-dev.txt
!/pyproject.toml
# F4.5: imagen Docker única de la plataforma
!/Dockerfile
!/.dockerignore

# --- Config y templates (datos chicos, fuente de verdad) ---
!/pbi_schema.json
!/condiciones_credito.json
!/activities_template.json
!/activities_template_*.json
!/activities_manifest.json
!/manifest.json

# --- Directorios del proyecto ---
!/azfunc/
!/tests/
!/tools/
!/docs/
!/archive/
!/.github/
# --- Plataforma multiempresa (andamiaje aditivo, F0/F1/F2) ---
!/core/
!/ops/
!/tenants/
!/connectors/

# --- Exclusiones dentro de directorios incluidos ---
# Staging viejo del bot (artefacto de deploy, no fuente; rollback = bot_deploy.zip)
archive/bot_deploy_stage_2026-06-02/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
azfunc/local.settings.json
azfunc/.python_packages/

# --- Nunca versionar (aunque matcheen un patrón de arriba) ---
# Caches de datos regenerables (grandes)
contifico_productos.json
contifico_norm.json
daily_news_brief.json
# Estado y credenciales
.claude-agent/
msal_cache.bin
*.log
